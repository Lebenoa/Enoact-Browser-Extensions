{
    "manifest_version": 3,
    "name": "Enoact",
    "description": "Show what you're doing to others!",
    "version": "1.0",
    "permissions": [
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "youtube.js"
            ]
        },
        {
            "matches": [
                "https://music.youtube.com/*"
            ],
            "js": [
                "youtube-music.js"
            ]
        }
    ],
    "action": {
        "default_title": "Enoact"
    }
}
